@BOOK{Montgomery20261,
	author = {Montgomery, Derek E. and Tompkins, Virginia},
	title = {Language and Theory of Mind: How Children Learn About the Mind Through Language},
	year = {2026},
	journal = {Language and Theory of Mind: How Children Learn About the Mind Through Language},
	pages = {1 - 374},
	doi = {10.1093/9780198909705.001.0001},
	url = {https://www.scopus.com/pages/publications/105039265446?origin=resultslist},
	abstract = {Theory of mind is the capacity for understanding how thoughts and feelings underlie what people say and do. It is the interpretive key that helps people make sense of the social world. Children's language acquisition is the pathway for their participation in the social world. With language, children share thoughts, feelings, and meaning with others. Together, theory of mind and language catalyze the development of social understanding in childhood. This book is about research and theory devoted to understanding how that happens. Research on language and theory of mind spans multiple disciplines and multiple decades. This book organizes and integrates the expansive literature, providing a comprehensive portrait of what we know, and still need to know, about the role of language in children's understanding of the mental world. The authors discuss how children come to talk about the mind, the contributions of caregiver-child conversation to theory of mind development, and the pragmatic skills infants and children need for a meeting of the minds within conversation. Coverage also explores the fundamental relation that theory of mind has with narrative comprehension and engagement with fiction throughout the lifespan. Excerpts from parent-child conversations in each chapter illuminate how the social use of language is tied to understanding the mind. The authors synthesize the language-theory of mind literature into a cohesive presentation intended for researchers and graduate students in psychology and related fields such as education, philosophy, and psycholinguistics, as well as practitioners who work with children in clinical and educational settings. © Derek E. Montgomery and Virginia Tompkins 2026.},
	type = {Book},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Liu2026,
	author = {Liu, Yixuan and Liu, Jiyun and Tan, Shuhan and Tang, Kinboon and Chen, Jiajing},
	title = {A systematic literature review of the application of UTAUT series models on hedonic gameplay},
	year = {2026},
	journal = {Entertainment Computing},
	volume = {58},
	pages = {},
	doi = {10.1016/j.entcom.2026.101145},
	url = {https://www.scopus.com/pages/publications/105039906993?origin=resultslist},
	abstract = {This study systematically reviews and summarizes existing studies that have applied the UTAUT series models (UTAUT, UTAUT2, and UTAUT3) to investigate hedonic gameplay intention and use behavior. The review was conducted in accordance with the PRISMA protocol, with a PICO-based search strategy applied across four major databases: Web of Science, Scopus, ProQuest, and IEEE. An initial total of 2,846 records was identified, and after four stages of screening using eight predefined inclusion criteria, 21 eligible studies published between 2011 and 2025 were included, comprising 18 journal articles and 3 conference papers. Among the reviewed studies, five employed the original UTAUT model, fifteen adopted UTAUT2, and one applied UTAUT3. The synthesis of findings indicates that social influence, hedonic motivation, and habit were the most frequently reported significant predictors of gameplay intention, whereas effort expectancy, social influence, and price value showed more context-dependent patterns across studies. In addition, the review reveals that most existing studies focus on post-adoptive use by experienced players, with limited attention to initial adoption stages, platform- or genre-specific moderation effects. As the first systematic literature review focusing specifically on the application of the UTAUT series models in hedonic gameplay contexts, this study provides a structured overview of research contexts, construct performance patterns, and model extensions, and offers directions for future theoretical refinement and empirical research. © 2026 The Author(s). Published by Elsevier B.V. This is an open access article under the CC BY-NC-ND license. http://creativecommons.org/licenses/by-nc-nd/4.0/},
	type = {Review},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Hybrid Gold Open Access}
}

